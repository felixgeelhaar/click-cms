{
    "name": "click/cms",
    "description": "A lightweight headless CMS with a full plugin system",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "Click\\Cms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Click\\Cms\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    }
}
